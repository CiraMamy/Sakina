{
  "expo": {
    "name": "Sakina",
    "slug": "sakina-mobile",
    "version": "1.0.0",
    "scheme": "sakina",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#8CB8E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sakina.mental",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#8CB8E8"
      },
      "package": "com.sakina.mental",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Sakina a besoin d'accéder à votre microphone pour l'enregistrement vocal."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
